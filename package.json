{
  "name": "frontend-para",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "link": "node ../scripts/link-aomi-widget.mjs && pnpm install",
    "unlink": "node ../scripts/link-aomi-widget.mjs --unlink && pnpm install",
    "dev": "next dev --turbopack",
    "dev:landing:ngrok": "./scripts/dev-landing-ngrok.sh",
    "dev:webpack": "next dev",
    "dev:localhost": "NEXT_PUBLIC_USE_LOCALHOST=true next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "type-check": "next typegen && tsc --noEmit --incremental false",
    "test": "node scripts/run-tests.mjs",
    "clean:next": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules",
    "clean": "rm -rf .next node_modules"
  },
  "comment": "Use AOMI_WIDGET_ROOT=/path/to/widget pnpm run link for a persistent local widget, or AOMI_WIDGET_ROOT=/path/to/widget pnpm dev for one-off use",
  "dependencies": {
    "@aomi-labs/react": "^0.3.11",
    "@assistant-ui/react": "^0.12.25",
    "@assistant-ui/react-markdown": "^0.12.9",
    "@getpara/evm-wallet-connectors": "^2.24.0",
    "@getpara/react-sdk": "^2.24.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "motion": "^12.38.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-shiki": "^0.9.3",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "viem": "^2.48.4",
    "wagmi": "^3.6.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@noble/hashes": "1.8.0",
    "@noble/curves": "1.9.1",
    "@scure/bip32": "1.7.0",
    "@scure/bip39": "1.6.0"
  }
}
